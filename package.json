{
  "name": "splinter-keyboard",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "config": {
    "VERSION": "v4"
  },
  "dependencies": {
    "ergogen": "^4.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "scripts": {
    "clean": "rm -rf dist && echo 'OK: clean: removed dist/'",
    "copy:dist-to-unrouted": "./scripts/copy-dist-to-unrouted.sh",
    "copy:traces-to-unrouted": "./scripts/copy-traces-to-unrouted.sh",
    "copy:unrouted-to-routed": "./scripts/copy-unrouted-to-routed.sh",
    "ergogen": "./scripts/ergogen.sh",
    "fab": "./scripts/fab.sh",
    "panelize": "./scripts/panelize.sh",
    "pipeline": "./scripts/pipeline.sh",
    "route": "python3 ./scripts/route.py",
    "validate:fab": "python3 ./scripts/validate-fab.py",
    "validate:provenance": "python3 ./scripts/validate-provenance.py",
    "watch": "nodemon --ext .js,.yaml --watch ./$npm_package_config_VERSION/ergogen/config.yaml --exec \"npm run ergogen\"",
    "watch:sync-unrouted": "nodemon --ext .js,.yaml --watch ./$npm_package_config_VERSION/ergogen/config.yaml --exec \"npm run ergogen && npm run copy:dist-to-unrouted\""
  }
}
